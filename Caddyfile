# Основной домен
ivantishchenko.ru {
    reverse_proxy localhost:8080
}

# API и подписки
api.ivantishchenko.ru {
    # Публичный доступ к календарям
    handle_path /api/cal/* {
        reverse_proxy 127.0.0.1:9583
    }

    # Всё остальное (статистика, дашборд)
    handle {
        reverse_proxy 127.0.0.1:9583
    }
}